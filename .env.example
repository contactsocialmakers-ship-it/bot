# Reddit API (create app at https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password

# Twitter/X API (https://developer.twitter.com)
TWITTER_BEARER_TOKEN=your_bearer_token

# LinkedIn — cookie method
# 1. Connecte-toi à LinkedIn dans Chrome
# 2. F12 → Application → Cookies → linkedin.com
# 3. Copie la valeur de "li_at"
# 4. Copie la valeur de "JSESSIONID" (sans les guillemets)
LINKEDIN_LI_AT=your_li_at_cookie_value
LINKEDIN_CSRF_TOKEN=your_jsessionid_value

# TaskerTime config
TASKERTIME_URL=https://taskertime.app
BOT_REPLY_SIGNATURE=TaskerTime

# Scan interval in minutes
SCAN_INTERVAL_MINUTES=5

# AI for contextual replies (optional but recommended)
# Without AI key, bot uses template-based replies
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
